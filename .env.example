# EdgeOne Agents server variables. Configure real values in EdgeOne or a local ignored .env file.
AI_GATEWAY_API_KEY=
AI_GATEWAY_BASE_URL=https://ai-gateway.edgeone.link/v1
AI_GATEWAY_MODEL=@makers/deepseek-v4-flash

# Production uses same-origin routes. Set this only when the API runs on another origin locally.
VITE_COPILOT_SERVER_URL=
